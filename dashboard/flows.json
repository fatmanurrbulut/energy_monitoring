      ]
    ]
  },
  {
    "id": "33be2ee7c45db1ad",
    "type": "function",
    "z": "f6f2187d.f17ca8",
    "name": "CSV to Chart Data",
    "func": "const raw = (msg.payload || \"\").toString();\nconst lines = raw.split(\"\\n\").filter(line => line && !line.startsWith(\"#\"));\n\nif (lines.length < 2) {\n    return [null, { payload: \"No historical data in last 1h\" }];\n}\n\nconst headers = lines[0].split(\",\");\nconst timeIndex = headers.indexOf(\"_time\");\nconst valueIndex = headers.indexOf(\"_value\");\n\nif (timeIndex === -1 || valueIndex === -1) {\n    return [null, { payload: \"Influx response parse error\" }];\n}\n\nconst points = [];\nfor (let i = 1; i < lines.length; i++) {\n    const cols = lines[i].split(\",\");\n    const t = cols[timeIndex];\n    const v = parseFloat(cols[valueIndex]);\n\n    if (!t || Number.isNaN(v)) {\n        continue;\n    }\n\n    points.push({ x: new Date(t).getTime(), y: v });\n}\n\nif (points.length === 0) {\n    return [null, { payload: \"No points parsed from Influx\" }];\n}\n\nconst chartMsg = {\n    payload: [\n        {\n            series: [\"1m Avg Power (W)\"],\n            data: [points],\n            labels: [\"\"]\n        }\n    ]\n};\n\nconst infoMsg = {\n    payload: `History updated: ${points.length} points (last 1h)`\n};\n\nreturn [chartMsg, infoMsg];",
    "outputs": 2,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 980,
    "y": 820,
    "wires": [
      [
        "4a0787865d9a6f52"
      ],
      [
        "dd90dfe6d56b2f2f"
      ]
    ]
  },
