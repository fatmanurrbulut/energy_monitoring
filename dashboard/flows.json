  {
    "id": "42dc76c638ea8ac3",
    "type": "function",
    "z": "f6f2187d.f17ca8",
    "name": "Build Flux Query",
    "func": "msg.method = \"POST\";\nmsg.url = \"http://influxdb:8086/api/v2/query?org=energy-org\";\nmsg.headers = {\n    \"Authorization\": \"Token energy-super-token\",\n    \"Content-Type\": \"application/vnd.flux\",\n    \"Accept\": \"application/csv\"\n};\nmsg.payload = `from(bucket: \"energy-bucket\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"energy_telemetry\")\n  |> filter(fn: (r) => r._field == \"power_est\")\n  |> filter(fn: (r) => r.device_id == \"device01\")\n  |> aggregateWindow(every: 1m, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")`;\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 510,
    "y": 820,
    "wires": [
      [
        "750748f0d5effc9a"
      ]
    ]
  },
  {
    "id": "750748f0d5effc9a",
    "type": "http request",
    "z": "f6f2187d.f17ca8",
    "name": "Influx Query",
    "method": "use",
    "ret": "txt",
    "paytoqs": "ignore",
    "url": "",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": false,
    "headers": [],
    "x": 730,
