[ req ]
default_bits       = 2048
distinguished_name = req_distinguished_name
x509_extensions    = v3_req
prompt             = no

[ req_distinguished_name ]
C  = TR
ST = Istanbul
L  = Istanbul
O  = EnergyMonitoring
CN = mosquitto

[ v3_req ]
subjectAltName = @alt_names

[ alt_names ]
DNS.1 = mosquitto
DNS.2 = localhost
IP.1  = 127.0.0.1
